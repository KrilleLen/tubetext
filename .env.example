APP_NAME=TubeText
ENVIRONMENT=production
DOCS_ENABLED=false

# Domäner som får anropa API:t direkt från webbläsaren.
# Separera flera domäner med kommatecken.
ALLOWED_ORIGINS=http://localhost:8000,https://www.din-hemsida.se

# Domäner som får bädda in appen via iframe/widget.
# Använd din riktiga webbdomän i produktion. Undvik * om du kan.
EMBED_ALLOWED_ORIGINS=http://localhost:8000,https://www.din-hemsida.se

CACHE_TTL_SECONDS=1800
CACHE_MAX_ITEMS=200
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
REQUEST_TIMEOUT_SECONDS=12

# Rekommenderas vid molndrift eftersom YouTube ofta blockerar datacenter-IP:n.
# Använd en leverantör och ett konto som du har rätt att använda.
YOUTUBE_PROXY_URL=
